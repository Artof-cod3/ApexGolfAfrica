# Frontend
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional auth hardening toggle: set to false only after migrating fully to OAuth/server-side auth
VITE_ENABLE_PASSWORD_LOGIN=true
# Customer care line shown in help widgets and booking emails
VITE_SUPPORT_WHATSAPP_NUMBER=0700000000
VITE_SUPPORT_WHATSAPP_E164=254700000000

# AI backend (Vercel serverless function)
# Optional: if not set, the app uses a free no-key provider fallback
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Optional: enables web search enrichment for the AI assistant
SERPER_API_KEY=your_serper_api_key

# Quickwave payments (set in Supabase function secrets, not client env)
# QUICKWAVE_API_BASE_URL=https://api.quickwave.example
# QUICKWAVE_WEBHOOK_URL=https://wkgxrgslsmkfvkrmotpl.supabase.co/functions/v1/quickwave-webhook
# Either set QUICKWAVE_API_KEY, or set all three below:
# QUICKWAVE_PUBLIC_KEY=pk_live_xxx
# QUICKWAVE_PRIVATE_KEY=sk_live_xxx
# QUICKWAVE_WALLET_ID=your_wallet_id

# Customer communication automation (Supabase function secrets)
# RESEND_API_KEY=re_xxx
# RECEIPT_FROM_EMAIL=ApexGolf Africa <bookings@apexgolf.africa>
# Optional customer care line used inside emails
# CUSTOMER_CARE_PHONE=+254700000000
# Optional WhatsApp relay endpoint that accepts {to, message, bookingReference, templateType}
# WHATSAPP_NOTIFIER_WEBHOOK_URL=https://your-whatsapp-relay.example/webhook
